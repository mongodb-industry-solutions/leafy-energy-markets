# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# Embedding/Reranking API
VOYAGE_API_KEY=

# ── LLM Provider (pick ONE) ───────────────────────────────────────────────────

# Option A: Direct Anthropic API (recommended — keys don't expire)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Azure AI Foundry — Claude Opus 4.6
# (comment out ANTHROPIC_API_KEY above if using Azure)
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/anthropic
