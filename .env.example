# ── MongoDB Atlas ──────────────────────────────────────────────────────────────
# Required. Connection string to your Atlas cluster.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# ── LLM Provider (pick ONE) ──────────────────────────────────────────────────
# The AI advisor and compliance analysis need an LLM.

# Option A: Direct Anthropic API (simplest)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Azure AI Foundry (comment out Option A if using this)
# AZURE_FOUNDRY_API_KEY=your-key
# AZURE_FOUNDRY_ENDPOINT=https://your-resource.services.ai.azure.com/api

# ── Embeddings (optional) ────────────────────────────────────────────────────
# VoyageAI voyage-finance-2 for document embeddings.
# If not set, falls back to deterministic hash embeddings (demo still works).
# VOYAGE_API_KEY=your-voyage-key
