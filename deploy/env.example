# MongoDB
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/

# Embedding/Reranking API
VOYAGE_API_KEY=

# ── LLM Provider (pick ONE) ───────────────────────────────────────────────────

# Option A: Direct Anthropic API (recommended — keys don't expire)
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Azure AI Foundry — Claude Opus 4.6
# (comment out ANTHROPIC_API_KEY above if using Azure)
# AZURE_FOUNDRY_API_KEY=
# AZURE_FOUNDRY_ENDPOINT=https://<your-resource>.services.ai.azure.com/anthropic

# ── Energy Data APIs (optional — tools fall back to DuckDuckGo if not set) ────

# EIA Open Data API — free petroleum spot prices (Brent, WTI, etc.)
# Register at https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# NewsAPI.org — energy market headlines
# Register at https://newsapi.org/register (free developer tier)
NEWS_API_KEY=
